{
  "name": "Orchestrator Agent",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "chat",
        "responseMode": "lastNode",
        "options": {}
      },
      "id": "webhook-node-1",
      "name": "Chat Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [
        250,
        300
      ],
      "webhookId": "shift-control-chat-webhook"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://openrouter.ai/api/v1/chat/completions",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"anthropic/claude-3.5-sonnet\",\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are the Orchestrator Agent for Shift Control, an e-commerce automation hub. Classify the user message into EXACTLY ONE of these four intents:\\n\\n- shopify: product management, inventory, orders, store updates (e.g. 'Shopify: update product description')\\n- social: social media posting, Instagram publishing, tweet drafting (e.g. 'Social: post this image')\\n- media: file ingestion, image/video upload to storage, media tagging — NOT social media (e.g. 'Media: ingest file', 'Media: upload this image')\\n- general: anything else, greetings, questions, unclear intent\\n\\nIMPORTANT: Respond with ONLY a raw JSON object. No markdown. No code fences. No backticks. No explanation. The exact format:\\n{ \\\"intent\\\": \\\"<one of: shopify|social|media|general>\\\", \\\"extracted_data\\\": \\\"<relevant details from the message>\\\", \\\"response_message\\\": \\\"<a brief friendly acknowledgement of the task, 1-2 sentences>\\\" }\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"{{ $json.body.message }}\"\n    }\n  ]\n}",
        "options": {}
      },
      "id": "openrouter-llm-node",
      "name": "OpenRouter LLM",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        450,
        300
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "YOUR_CREDENTIAL_ID",
          "name": "OpenRouter API Key"
        }
      }
    },
    {
      "parameters": {
        "dataType": "string",
        "value1": "={{ JSON.parse($json.choices[0].message.content).intent }}",
        "rules": {
          "rules": [
            {
              "value2": "shopify",
              "output": 0
            },
            {
              "value2": "social",
              "output": 1
            },
            {
              "value2": "media",
              "output": 2
            },
            {
              "value2": "general",
              "output": 3
            }
          ]
        }
      },
      "id": "intent-router",
      "name": "Route by Intent",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 1,
      "position": [
        650,
        300
      ]
    },
    {
      "parameters": {
        "keepOnlySet": true,
        "values": {
          "string": [
            {
              "name": "output",
              "value": "={{ JSON.parse($('OpenRouter LLM').item.choices[0].message.content).response_message }}"
            },
            {
              "name": "agent",
              "value": "Shopify Manager"
            }
          ]
        },
        "options": {}
      },
      "id": "format-shopify-response",
      "name": "Format Shopify Response",
      "type": "n8n-nodes-base.set",
      "typeVersion": 2,
      "position": [
        900,
