# -----------------------------------------------------------------------------
# SHIFT CONTROL - ENVIRONMENT VARIABLES
# -----------------------------------------------------------------------------

# ==========================================
# 1. FRONTEND / UI CONFIGURATION
# ==========================================
# The domain or IP pointing to this server (e.g., https://shiftcontrol.yourdomain.com)
DOMAIN_NAME=https://chat.almostrolledit.com
TIMEZONE=America/New_York

# Default routing URL for the frontend UI to talk to n8n
# If testing locally, use: http://localhost:5678/webhook/chat
# If VPS deployed, use: https://<DOMAIN_NAME>/webhook/chat
VITE_N8N_WEBHOOK_URL=http://n8n.almostrolledit.com/webhook/chat

# ==========================================
# 2. CORE INFRASTRUCTURE (n8n & Postgres)
# ==========================================
POSTGRES_USER=n8n
POSTGRES_PASSWORD=secure_db_password_here
POSTGRES_DB=n8n

# Login credentials for the n8n Admin Dashboard
N8N_USER=admin
N8N_PASSWORD=secure_n8n_password_here

# ==========================================
# 3. EXTERNAL API KEYS & CREDENTIALS
# ==========================================
# (Note: Some of these can also be configured directly via the n8n Credentials UI)

# OpenRouter (Required for LLM Routing & Agent logic)
OPENROUTER_API_KEY=sk-or-v1-...

# Shopify (Required by Shopify Manager Agent for product listing updates)
SHOPIFY_STORE_URL=https://your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_...

# Google Cloud / Google Drive (Required for Media Ingest Agent)
# As we are using a Service Account JSON file, there are no Client ID/Secret variables needed here.
# Ensure `google_service_account.json` is present in the root directory. It will be mounted into n8n at `/home/node/google_service_account.json`.
