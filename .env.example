# -----------------------------------------------------------------------------
# SHIFT CONTROL - ENVIRONMENT VARIABLES
# -----------------------------------------------------------------------------

# ==========================================
# 1. FRONTEND / UI CONFIGURATION
# ==========================================
# The domain or IP pointing to this server (e.g., https://shiftcontrol.yourdomain.com)
DOMAIN_NAME=https://chat.almostrolledit.com
TIMEZONE=America/New_York

# Default routing URL for the frontend UI to talk to n8n
# Connect this to your existing n8n instance
VITE_N8N_WEBHOOK_URL=https://n8n.almostrolledit.com/webhook/chat

# OpenRouter (Required for LLM Routing inside the chat interface directly)
# Note: You also need this key configured inside your n8n Credentials!
VITE_OPENROUTER_API_KEY=sk-or-v1-...
